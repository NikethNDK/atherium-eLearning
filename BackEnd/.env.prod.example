# Production environment template for Aetherium Backend
# Copy to .env.prod on the server and fill in real values. Do not commit .env.prod.
# Usage: env_file: .env.prod in docker-compose.prod.yml

# App
ENV_FILE=.env.prod

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_MIN=10080
BLACKLIST_TOKEN_EXPIRE_DAYS=7

# Database (used by backend; postgres service also needs POSTGRES_*)
DATABASE_URL=postgresql://user:password@postgres:5432/aetherium_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=aetherium_db

# Redis (backend + Celery)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Frontend (for CORS, redirects)
FRONTEND_URL=https://aetherium.wiki

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.aetherium.wiki/auth/google/callback

# SMTP (email)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@aetherium.wiki

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary (media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
